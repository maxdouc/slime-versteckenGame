[node name="WorldEnvironment" type="WorldEnvironment" parent="." unique_id=1408365916]
environment = SubResource("Environment_house")

; Sun energy pulled down from the default 1.0: with the new ambient + per-room
; fill lights carrying the base exposure, the directional is now an accent, so
; the lit/dark contrast (the "hard shadow" edge) is much gentler. Cast shadows
; stay off (default) — they are the expensive part on the web renderer and would
; reintroduce the dark faces we are removing.
[node name="DirectionalLight3D" type="DirectionalLight3D" parent="." unique_id=1408365915]
transform = Transform3D(0.8660254, 0.38302222, -0.32139382, 0, 0.64278764, 0.76604444, 0.5, -0.66341394, 0.5566704, 0, 8, 0)
light_energy = 0.7

; One dim, shadowless OmniLight per living room — analogous to the seeker room's
; BoxLight — placed just under the 3 m wall top at each room centre. Lights the
; walls and props from a second (overhead) direction so surfaces read from all
; sides. Shadowless omnis are cheap; each walled room exposes only its own light
; plus the sun to any prop, well under the compatibility per-object light cap.
[node name="RoomLight_kueche" type="OmniLight3D" parent="." unique_id=1408365930]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -6, 2.6, -6)
light_energy = 0.6
omni_range = 8.0

