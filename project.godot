; Godot 4.7 project file — Slime-Verstecken (Arbeitstitel)
; Single source of truth for gameplay = SPEC.md. This file only wires the project.
; NO GodotSteam: Steamworks is native and does not run in a browser (WASM).
; Transport lives behind the Net autoload so a later Steam port is a peer swap.

config_version=5

[application]

config/name="Slime-Verstecken"
config/description="Multiplayer prop-hunt + painting. Web-first, Steam = V2."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

Net="*res://net/net.gd"
GameState="*res://scripts/game_state.gd"

[rendering]

; Flat-color friendly: paintable surfaces read cleaner without heavy post.
textures/canvas_textures/default_texture_filter=0
